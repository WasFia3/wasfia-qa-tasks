{
  "info": {
    "_postman_id": "b6f2f5b0-1c3a-4b7a-9e1a-trello-checklist-api",
    "name": "Trello - Create Checklist in Card",
    "description": "API Test Final task. Creates a Checklist on a Trello Card and verifies the response with Postman tests. Uses a collection variable `ChecklistName` so the same request can be exercised with different checklist names.\n\nEnvironment variables required: `baseUrl`, `TRELLO_KEY`, `TRELLO_TOKEN`, `CARD_ID`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Status code is 200\", function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test(\"Response is JSON\", function () {",
          "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
          "});",
          "",
          "pm.test(\"Checklist name in response matches the ChecklistName collection variable\", function () {",
          "    const responseJson = pm.response.json();",
          "    const expectedName = pm.collectionVariables.get(\"ChecklistName\");",
          "    pm.expect(responseJson.name).to.eql(expectedName);",
          "});",
          "",
          "pm.test(\"Checklist is attached to the expected card\", function () {",
          "    const responseJson = pm.response.json();",
          "    pm.expect(responseJson.idCard).to.eql(pm.environment.get(\"CARD_ID\"));",
          "});",
          "",
          "pm.test(\"Response has an id and empty checkItems\", function () {",
          "    const responseJson = pm.response.json();",
          "    pm.expect(responseJson.id).to.be.a(\"string\");",
          "    pm.expect(responseJson.checkItems).to.be.an(\"array\");",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "ChecklistName",
      "value": "QA Automation Checklist",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Create Checklist in Card",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/1/cards/{{CARD_ID}}/checklists?name={{ChecklistName}}&key={{TRELLO_KEY}}&token={{TRELLO_TOKEN}}",
          "host": ["{{baseUrl}}"],
          "path": ["1", "cards", "{{CARD_ID}}", "checklists"],
          "query": [
            { "key": "name", "value": "{{ChecklistName}}" },
            { "key": "key", "value": "{{TRELLO_KEY}}" },
            { "key": "token", "value": "{{TRELLO_TOKEN}}" }
          ]
        },
        "description": "Creates a checklist on the card {{CARD_ID}} using the current value of the ChecklistName collection variable."
      },
      "response": []
    },
    {
      "name": "Different ChecklistName Examples",
      "description": "Same request, reusing the ChecklistName collection variable with a different value set in each pre-request script.",
      "item": [
        {
