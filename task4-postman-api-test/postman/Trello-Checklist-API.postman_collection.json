              "host": ["{{baseUrl}}"],
              "path": ["1", "cards", "{{CARD_ID}}", "checklists"],
              "query": [
                { "key": "name", "value": "{{ChecklistName}}" },
                { "key": "key", "value": "{{TRELLO_KEY}}" },
                { "key": "token", "value": "{{TRELLO_TOKEN}}" }
              ]
            }
          },
          "response": []
