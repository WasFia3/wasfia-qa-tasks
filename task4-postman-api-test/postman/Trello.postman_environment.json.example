{
  "id": "trello-checklist-api-env",
  "name": "Trello Checklist API",
  "values": [
    {
      "key": "baseUrl",
      "value": "https://api.trello.com",
      "type": "default",
      "enabled": true
    },
    {
      "key": "TRELLO_KEY",
      "value": "your-trello-api-key",
      "type": "secret",
      "enabled": true
    },
    {
      "key": "TRELLO_TOKEN",
      "value": "your-trello-api-token",
      "type": "secret",
      "enabled": true
    },
    {
      "key": "CARD_ID",
      "value": "your-trello-card-id-or-shortlink",
      "type": "default",
      "enabled": true
    }
  ],
  "_postman_variable_scope": "environment"
}
