{
  "name": "task3-saucedemo",
  "version": "1.0.0",
  "description": "Task 3 - SauceDemo automation with Cypress + Cucumber (Login, Checkout, Logout)",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run --spec \"cypress/e2e/features/**/*.feature\"",
    "test:login": "cypress run --spec \"cypress/e2e/features/login.feature\"",
    "test:checkout": "cypress run --spec \"cypress/e2e/features/checkout.feature\"",
    "test:logout": "cypress run --spec \"cypress/e2e/features/logout.feature\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^26.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.17.0",
    "esbuild": "^0.28.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.js"
    ]
  }
}
