{
  "name": "wasfia-qa-tasks",
  "version": "1.0.0",
  "description": "QA automation tasks - Final Task: Trello with Cypress + Cucumber + POM",
  "main": "cypress.config.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:trello": "cypress run --spec \"cypress/e2e/features/**/*.feature\"",
    "test:smoke": "cypress run --spec \"cypress/e2e/features/**/*.feature\" --env tags=@smoke",
    "test:regression": "cypress run --spec \"cypress/e2e/features/**/*.feature\" --env tags=@regression"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WasFia3/wasfia-qa-tasks.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/WasFia3/wasfia-qa-tasks/issues"
  },
  "homepage": "https://github.com/WasFia3/wasfia-qa-tasks#readme",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^26.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.17.0",
    "esbuild": "^0.28.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.js"
    ]
  }
}
